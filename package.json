{
  "name": "cantonctl",
  "description": "Institutional-grade CLI toolchain for building on Canton Network",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Merged One",
  "homepage": "https://github.com/merged-one/cantonctl",
  "repository": {
    "type": "git",
    "url": "https://github.com/merged-one/cantonctl.git"
  },
  "bugs": {
    "url": "https://github.com/merged-one/cantonctl/issues"
  },
  "type": "module",
  "main": "",
  "bin": {
    "cantonctl": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "shx rm -rf dist",
    "lint": "eslint src/",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e-sdk --project e2e-sandbox",
    "test:e2e:sdk": "vitest run --project e2e-sdk",
    "test:e2e:sandbox": "vitest run --project e2e-sandbox",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "ci": "bash scripts/ci-local.sh"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-warn-if-update-available": "^3",
    "chokidar": "^4",
    "cli-table3": "^0.6",
    "execa": "^9",
    "inquirer": "^12",
    "jose": "^6",
    "js-yaml": "^4",
    "ora": "^8",
    "picocolors": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@oclif/test": "^4",
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3.2.4",
    "memfs": "^4",
    "nock": "^14",
    "oclif": "^4",
    "shx": "^0.3",
    "strip-ansi": "^7",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "cantonctl",
    "dirname": "cantonctl",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-warn-if-update-available"
    ],
    "topicSeparator": " ",
    "topics": {
      "dev": {
        "description": "Local development environment"
      },
      "deploy": {
        "description": "Deploy to Canton networks"
      }
    },
    "hooks": {
      "init": "./dist/hooks/init",
      "prerun": "./dist/hooks/prerun"
    }
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
